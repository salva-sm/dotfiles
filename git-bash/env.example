# ─── Local dotfiles configuration (personal, not versioned) ───
# Copy to env.local and adjust:  cp git-bash/env.example git-bash/env.local
# env.local is gitignored. After editing, run ./install.sh to regenerate the
# VS Code workspace (its JSON can't read env vars directly).

# Label VS Code shows for the project folder.
export SFCC_PROJECT_NAME="📦 SFCC Project"

# Path to your project, RELATIVE to vscode/workspaces/ in this repo.
# e.g. project at ~/Github/my-project -> ../../../my-project
export SFCC_PROJECT_DIR="../../../CHANGE_ME"

# Second workspace folder: the Playwright end-to-end test repo
# (github.com/shopguess/sfcc-playwright-test). Same relative-path rule as above.
export PLAYWRIGHT_PROJECT_NAME="🎭 Playwright Tests"
export PLAYWRIGHT_PROJECT_DIR="../../../sfcc-playwright-test"
